# =====================================================================
# Variables d'environnement — copier ce fichier en `.env.local`
# (.env.local est gitignoré : ne JAMAIS committer la service_role key)
# =====================================================================

# URL du projet Supabase (ex. https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clé publique "anon" (exposée côté client, protégée par la RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé "service_role" — SECRÈTE, serveur uniquement (bypass RLS).
# Sert à provisionner les comptes patients (création par la coordinatrice).
SUPABASE_SERVICE_ROLE_KEY=

# --- Stubs (intégrations à brancher plus tard, cf. §10 du cahier des charges) ---
# Fournisseur SMS (Twilio / OVH) — laissé vide en prototype
SMS_PROVIDER=stub
# Délai (minutes) avant escalade SMS n°1 -> n°2
ESCALADE_DELAI_MINUTES=15
# Source météo pour les conseils déclenchés
METEO_API_KEY=
