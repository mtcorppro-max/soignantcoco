# Copier ce fichier en .env.local et remplir les valeurs

# Supabase — espace public (frontend)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx

# Supabase — clé service_role (BACKEND uniquement, ne jamais exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxx

# SMS (stub = simulation, sinon mettre twilio ou autre)
SMS_PROVIDER=stub

# Délai en minutes avant escalade d'alerte si non acquittée
ESCALADE_DELAI_MINUTES=15
